# Local .terraform directories
**/.terraform/*

# Include dependency lock files (overrides global gitignore)
!.terraform.lock.hcl

# Terragrunt cache
**/.terragrunt-cache/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
tfplan
plan.txt

# Ignore sensitive environment variables
.env
.env.local
.env.*$
!.env.sops.enc$ # Explicitly include this file
!.env.template$ # Explicitly include this file

# Ignore runtime data and volume mounts
volumes/
**/volumes/
**/data/
**/logs/
**/cache/
**/storage/
**/__pycache__/

# Ignore common local files
*.db
*.db-shm
*.db-wal
*.log
*.sock
*.pid
*.pem
*.key
*.crt
*.sqlite
*.bak

# Ignore editor and OS-specific files
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Claude Code
.claude/*
!.claude/CLAUDE.md
!.claude/settings.json

# Ansible secrets (plaintext)
ansible/secrets.yml

# Beads issue tracking
.beads/dolt/
.beads/dolt-access.lock
.beads/bd.sock
.beads/bd.sock.startlock
.beads/sync-state.json
.beads/last-touched
.beads/.local_version
.beads/redirect
.beads/.sync.lock
.beads/.jsonl.lock
.beads/sync_base.jsonl
.beads/export-state/
.beads/ephemeral.sqlite3*
.beads/*.db
.beads/*.db?*
.beads/*.db-journal
.beads/*.db-wal
.beads/*.db-shm
.beads/bd.db
.beads/daemon.lock
.beads/daemon.log
.beads/daemon-*.log.gz
.beads/daemon.pid
.beads/beads.base.jsonl
.beads/beads.base.meta.json
.beads/beads.left.jsonl
.beads/beads.left.meta.json
.beads/beads.right.jsonl
.beads/beads.right.meta.json

# Dolt database files (added by bd init)
.dolt/
