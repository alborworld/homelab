[Unit]
Description=OpenClaw AI Assistant Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ openclaw_user }}
Group={{ openclaw_user }}
WorkingDirectory={{ openclaw_home }}
Environment="HOME={{ openclaw_home }}"
Environment="PATH={{ openclaw_home }}/.local/bin:/usr/local/bin:/usr/bin:/bin"
Environment="OLLAMA_HOST={{ openclaw_ollama_host }}"
ExecStart={{ openclaw_home }}/.local/bin/openclaw gateway start
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
