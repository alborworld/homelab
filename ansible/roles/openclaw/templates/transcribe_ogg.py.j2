#!/usr/bin/env python3
"""Transcribe audio files using faster-whisper.

Usage: transcribe_ogg.py <audio_file>
Returns transcribed text to stdout.
"""
import sys
from faster_whisper import WhisperModel

if len(sys.argv) < 2:
    print("Usage: transcribe_ogg.py <audio_file>", file=sys.stderr)
    sys.exit(1)

audio_path = sys.argv[1]
model = WhisperModel("{{ whisper_model_size }}", device="cpu", compute_type="{{ whisper_compute_type }}")
segments, info = model.transcribe(
    audio_path,
    vad_filter=True,
{% if whisper_language %}
    language="{{ whisper_language }}",
{% endif %}
)

text = "".join(seg.text for seg in segments).strip()
print(text)
