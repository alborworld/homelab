#!/usr/bin/env python3
"""Configure model priority in openclaw.json.

Idempotent: prints 'changed' only if config was modified.
"""
import json
import sys

CONFIG_PATH = "{{ openclaw_home }}/.openclaw/openclaw.json"

DESIRED_MODEL_CONFIG = {
    "primary": "{{ openclaw_primary_model }}",
    "fallbacks": ["{{ openclaw_fallback_model }}"]
}

try:
    with open(CONFIG_PATH) as f:
        cfg = json.load(f)
except FileNotFoundError:
    print("error: openclaw.json not found — run onboarding first", file=sys.stderr)
    sys.exit(1)

current = cfg.get("agents", {}).get("defaults", {}).get("model")

if current == DESIRED_MODEL_CONFIG:
    print("ok")
    sys.exit(0)

cfg.setdefault("agents", {}).setdefault("defaults", {})["model"] = DESIRED_MODEL_CONFIG

with open(CONFIG_PATH, "w") as f:
    json.dump(cfg, f, indent=2)

print("changed")
