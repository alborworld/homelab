#!/usr/bin/env python3
"""Configure Edge TTS in openclaw.json.

Idempotent: prints 'changed' only if config was modified.
"""
import json
import sys

CONFIG_PATH = "{{ openclaw_home }}/.openclaw/openclaw.json"

DESIRED_TTS_CONFIG = {
    "auto": "{{ tts_auto }}",
    "provider": "{{ tts_provider }}",
    "edge": {
        "voice": "{{ edge_tts_voice }}"
    }
}

try:
    with open(CONFIG_PATH) as f:
        cfg = json.load(f)
except FileNotFoundError:
    print("error: openclaw.json not found — run onboarding first", file=sys.stderr)
    sys.exit(1)

messages = cfg.setdefault("messages", {})
current = messages.get("tts")

if current == DESIRED_TTS_CONFIG:
    print("ok")
    sys.exit(0)

messages["tts"] = DESIRED_TTS_CONFIG

# Clean up any stale top-level tts key
cfg.pop("tts", None)
if "tts" in cfg.get("tools", {}):
    cfg["tools"].pop("tts")

with open(CONFIG_PATH, "w") as f:
    json.dump(cfg, f, indent=2)

print("changed")
